# SEABeacon environment variables
# Copy to .env and fill in your Telegram bot token (from @BotFather).

TELEGRAM_BOT_TOKEN=

# Backend (local dev). On Vercel/Lambda the SQLite path is auto-rewritten
# to /tmp/ since the working directory is read-only there.
DATABASE_URL=sqlite:///./seabeacon.db
API_BASE_URL=http://localhost:8000

# Frontend
# Leave NEXT_PUBLIC_API_BASE_URL UNSET in production. The dashboard auto-
# detects: localhost → http://localhost:8000, any other origin (Vercel)
# → /_/backend (per vercel.json). Setting it to http://localhost:8000
# here would cause the deployed dashboard to try to fetch from localhost.
# For local dev only, you can uncomment the next line:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Free public MapLibre style. Replace with your own MapTiler / Stadia key for production.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
